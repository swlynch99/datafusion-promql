{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"$CLAUDE_CODE_REMOTE\" = \"true\" ] && { input=$(cat); echo \"$input\" | jq -r '.tool_input.command // empty' | grep -q 'git commit' && cargo +nightly fmt --all 2>/dev/null; } || true",
            "timeout": 60,
            "statusMessage": "Running cargo fmt..."
          }
        ]
      }
    ]
  }
}
